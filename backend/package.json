{
  "name": "@bloodconnect/backend",
  "version": "0.1.0",
  "description": "BloodConnect API — Choudhari EduHealth India Foundation",
  "private": true,
  "main": "src/server.js",
  "type": "commonjs",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "start": "node src/server.js",
    "dev": "node --watch src/server.js",
    "lint": "eslint src",
    "format": "prettier --write \"src/**/*.{js,json,md}\"",
    "format:check": "prettier --check \"src/**/*.{js,json,md}\"",
    "migrate": "node ../scripts/run_migrations.js up",
    "migrate:dry": "node ../scripts/run_migrations.js dry-run",
    "migrate:status": "node ../scripts/run_migrations.js status",
    "test": "echo \"No tests yet — added in later phases\" && exit 0"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.2",
    "express-async-errors": "^3.1.1",
    "express-rate-limit": "^7.4.1",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.2",
    "node-cron": "^4.2.1",
    "otplib": "^13.4.0",
    "pg": "^8.13.1",
    "pino": "^9.5.0",
    "pino-pretty": "^11.3.0",
    "qrcode": "^1.5.4",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "eslint": "^9.15.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-no-secrets": "^1.1.2",
    "globals": "^15.12.0",
    "prettier": "^3.3.3"
  }
}
