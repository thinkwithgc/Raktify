# Raktify .env template for the LOCAL-LAPTOP DEMO environment.
# Copy to .env.demo (gitignored) and fill in the Neon URL. Never commit a real
# DATABASE_URL — Neon connection strings carry the role password in plaintext.
#
# Use this with the local-laptop demo workflow described in docs/DEPLOYMENT.md
# §2.2. Hospital / blood-bank prospect demos run on the demo laptop against a
# Neon branch (free) — they do NOT touch the live Azure production environment.
#
# To activate before a demo:
#   cp .env.demo .env                          # or use `dotenv -e .env.demo …`
#   npm run dev:backend                        # http://localhost:3000
#   npm run dev:frontend                       # http://localhost:5173
#
# After a demo, refresh demo data:
#   DATABASE_URL=<neon> node scripts/seed_demo.js --reset

# ──────────────── Application ────────────────
NODE_ENV=development
PORT=3000
FRONTEND_URL=http://localhost:5173
LOG_LEVEL=info
JWT_SECRET=demo-only-jwt-secret-not-for-production-replace-with-32-bytes-of-random
JWT_EXPIRES_IN=8h

# ──────────────── Database (Neon demo branch) ────────────────
# Project: raktify-demo on Neon (console.neon.tech)
# Branch:  production (Neon's default branch name — see DEPLOYMENT.md §2.2)
# Region:  ap-southeast-1 (Singapore — closest free region; ~50 ms latency to India)
# Get the URL: Neon console → project → Connection details → Copy snippet
DATABASE_URL=postgresql://neondb_owner:<password>@ep-<host>.neon.tech/neondb?sslmode=require&channel_binding=require

# ──────────────── Provider selection (demo mode) ────────────────
ENCRYPTION_PROVIDER=local
NOTIFICATIONS_PROVIDER=console                # no real WhatsApp delivery during demos
STORAGE_PROVIDER=local
MAIL_PROVIDER=console

LOCAL_ENCRYPTION_KEY_HEX=00112233445566778899aabbccddeeff00112233445566778899aabbccddeeff
LOCAL_SCREENING_ENCRYPTION_KEY_HEX=ffeeddccbbaa99887766554433221100ffeeddccbbaa99887766554433221100
LOCAL_STORAGE_DIR=./.local-storage
LOCAL_OUTBOX_DIR=./.outbox

# ──────────────── Staging-style OTP echo (DEMOS ONLY) ────────────────
# When true, the OTP is echoed in the /auth/otp/send response so OTP login
# works end-to-end without WhatsApp / SMS. NEVER true in production.
OTP_ECHO=true

# ──────────────── WhatsApp Cloud (intentionally blank for demos) ────────────────
# Leave blank — demos use NOTIFICATIONS_PROVIDER=console so no real Meta sends.
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_WABA_ID=
WHATSAPP_APP_SECRET=
WHATSAPP_WEBHOOK_VERIFY_TOKEN=
WHATSAPP_API_VERSION=v21.0

# ──────────────── LeegAlly (skip during demos) ────────────────
LEEGALLY_API_KEY=
LEEGALLY_TEMPLATE_ID=
LEEGALLY_BASE_URL=https://api.leegally.com

# ──────────────── LGD (not needed for demo — data already seeded) ────────────────
LGD_USE_API=false
