# Dependencies
node_modules/
.pnp/
.pnp.js

# Build output
dist/
build/
*.tsbuildinfo

# Environment & secrets
# All .env / .env.* files are ignored by default — they routinely contain DB
# passwords, JWT secrets, API tokens. Explicit *.example templates are
# re-included so the schema of "what env vars exist" stays documented.
# Catches: .env, .env.local, .env.demo, .env.production, .env.azure-staging-backup,
# any future .env.<environment>, etc.
.env
.env.*
!.env.example
!.env.demo.example
!.env.production.example
!.env.staging.example
*.pem
*.key

# Logs
logs/
*.log
npm-debug.log*

# Editor / OS
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp

# Coverage
coverage/
.nyc_output/

# Local dev artifacts
.local-storage/
.outbox/
local-kms-key.bin
*.dump
*.bak

# Azure cutover script outputs (contain DB passwords, deploy tokens — never commit)
*-output.env
docs/azure-cutover/*.env

# Vendor docs the user pastes locally for reference (Leegality, Meta, etc.)
# These are the vendor's IP, not ours to redistribute. Read locally, code
# against them, but don't commit. To commit a SPECIFIC doc you want to
# preserve as reference, copy it to docs/ explicitly.
leegality.md/

# OneDrive sync turds
~$*
.tmp.driveupload/

# Frontend
frontend/dist/
.parcel-cache/

# Cached LGD downloads (large)
data/lgd/*.csv
data/lgd/*.zip

# Claude Code per-user settings
.claude/settings.local.json
