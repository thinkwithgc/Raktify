{
  "$schema": "https://json.schemastore.org/staticwebapp.config.json",
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": [
      "/assets/*",
      "*.{js,css,svg,png,ico,webmanifest,json,txt,xml}"
    ]
  },
  "routes": [
    { "route": "/privacy", "rewrite": "/privacy.html" },
    { "route": "/terms", "rewrite": "/terms.html" },
    { "route": "/data-deletion", "rewrite": "/data-deletion.html" },
    {
      "route": "/assets/*",
      "headers": { "cache-control": "public, max-age=31536000, immutable" }
    },
    {
      "route": "/index.html",
      "headers": { "cache-control": "no-cache" }
    },
    {
      "route": "/sw.js",
      "headers": { "cache-control": "no-cache" }
    },
    {
      "route": "/manifest.webmanifest",
      "headers": { "cache-control": "no-cache" }
    },
    {
      "route": "/robots.txt",
      "headers": { "cache-control": "public, max-age=3600", "content-type": "text/plain; charset=utf-8" }
    },
    {
      "route": "/sitemap.xml",
      "headers": { "cache-control": "public, max-age=3600", "content-type": "application/xml; charset=utf-8" }
    }
  ],
  "responseOverrides": {
    "404": { "rewrite": "/index.html", "statusCode": 200 }
  },
  "globalHeaders": {
    "X-Content-Type-Options": "nosniff",
    "Referrer-Policy": "no-referrer"
  }
}
