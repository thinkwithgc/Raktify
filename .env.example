# Raktify environment template. Copy to .env and fill in real values.
# Never commit .env. Never put real secrets in this file.

# ──────────────── Application ────────────────
NODE_ENV=development
PORT=3000
FRONTEND_URL=http://localhost:5173
LOG_LEVEL=info

# 8h for institutional users, 12h coordinators, 24h donors. JWT_SECRET must be a 64+ char random string.
JWT_SECRET=
JWT_EXPIRES_IN=8h

# ──────────────── Database ────────────────
# Neon for dev + staging. Append ?sslmode=require.
DATABASE_URL=
# Production cutover target: Azure Database for PostgreSQL Flexible Server (Central India / Pune).
# Leave blank until cutover; staging continues on the Neon URL above.
DATABASE_URL_PROD=

# ──────────────── Provider selection ────────────────
# encryption: local                  (Azure Key Vault-native provider is future work)
ENCRYPTION_PROVIDER=local
# notifications: console | msg91 | whatsapp_cloud   ← whatsapp_cloud is the live primary channel
NOTIFICATIONS_PROVIDER=console
# storage: local                     (Azure Blob Storage provider is future work; the spec's 's3' is a leftover)
STORAGE_PROVIDER=local
# mail: console | workspace
MAIL_PROVIDER=console

# Local providers
# 32-byte hex key for local AES-256-GCM encryption (dev only). Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
LOCAL_ENCRYPTION_KEY_HEX=
LOCAL_SCREENING_ENCRYPTION_KEY_HEX=
LOCAL_STORAGE_DIR=./.local-storage
LOCAL_OUTBOX_DIR=./.outbox

# ──────────────── MSG91 (SMS-fallback channel — stubbed) ────────────────
# Now the SECONDARY notification path. WhatsApp Cloud (Meta-direct) is primary.
# Activates only when NOTIFICATIONS_PROVIDER=msg91 (typically for the WA→SM→CA
# fallback chain). Requires India DLT registration.
MSG91_AUTH_KEY=
MSG91_SENDER_ID=RAKTFY
MSG91_WHATSAPP_NUMBER=                   # legacy — WhatsApp now ships via Meta direct, not MSG91
MSG91_TEMPLATE_OTP=
MSG91_TEMPLATE_EMERGENCY_MR=
MSG91_TEMPLATE_EMERGENCY_HI=
MSG91_TEMPLATE_THANKYOU_MR=
MSG91_TEMPLATE_REMINDER_MR=
MSG91_TEMPLATE_CRED=

# ──────────────── WhatsApp Business Cloud API (Meta, direct) ────────────────
# Used when NOTIFICATIONS_PROVIDER=whatsapp_cloud. No BSP, no India DLT for
# WhatsApp. Values come from Meta: developers.facebook.com app + WhatsApp product.
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_WABA_ID=
WHATSAPP_APP_SECRET=
# A random string you choose; entered in the Meta webhook config too.
WHATSAPP_WEBHOOK_VERIFY_TOKEN=
WHATSAPP_API_VERSION=v21.0
# Meta-approved template names (per templateType).
WHATSAPP_TEMPLATE_OTP=
WHATSAPP_TEMPLATE_EMERGENCY=
WHATSAPP_TEMPLATE_THANKYOU=
WHATSAPP_TEMPLATE_REMINDER=
WHATSAPP_TEMPLATE_CRED=

# Staging only: echo the OTP in the /auth/otp/send response so a live staging
# site can be demoed without an SMS/WhatsApp channel. Leave false in production.
OTP_ECHO=false

# ──────────────── LeegAlly (Aadhaar eSign) ────────────────
LEEGALLY_API_KEY=
LEEGALLY_TEMPLATE_ID=
LEEGALLY_BASE_URL=https://api.leegally.com

# ──────────────── LGD (Local Government Directory) ────────────────
# Public dataset from Ministry of Panchayati Raj. Either CSV (download from lgdirectory.gov.in)
# or API. Set USE_API=true to fetch live; otherwise importer reads CSVs from data/lgd/.
LGD_USE_API=true
LGD_API_BASE=https://lgdirectory.gov.in/api
LGD_API_KEY=
LGD_CSV_DIR=./data/lgd
