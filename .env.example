# BloodConnect environment template. Copy to .env and fill in real values.
# Never commit .env. Never put real secrets in this file.

# ──────────────── Application ────────────────
NODE_ENV=development
PORT=3000
FRONTEND_URL=http://localhost:5173
LOG_LEVEL=info

# 8h for institutional users, 12h coordinators, 24h donors. JWT_SECRET must be a 64+ char random string.
JWT_SECRET=
JWT_EXPIRES_IN=8h

# ──────────────── Database ────────────────
# Neon for dev. Append ?sslmode=require for Neon.
DATABASE_URL=
# Production target (AWS RDS Mumbai). Leave blank until go-live.
DATABASE_URL_PROD=

# ──────────────── AWS (post-go-live) ────────────────
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET_NAME=bloodconnect-documents
KMS_MAIN_KEY_ARN=
KMS_SCREENING_KEY_ARN=

# ──────────────── Provider selection (dev vs prod) ────────────────
# encryption: local | kms
ENCRYPTION_PROVIDER=local
# notifications: console | msg91
NOTIFICATIONS_PROVIDER=console
# storage: local | s3
STORAGE_PROVIDER=local
# mail: console | workspace
MAIL_PROVIDER=console

# Local providers
# 32-byte hex key for local AES-256-GCM encryption (dev only). Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
LOCAL_ENCRYPTION_KEY_HEX=
LOCAL_SCREENING_ENCRYPTION_KEY_HEX=
LOCAL_STORAGE_DIR=./.local-storage
LOCAL_OUTBOX_DIR=./.outbox

# ──────────────── MSG91 ────────────────
MSG91_AUTH_KEY=
MSG91_SENDER_ID=BLDCNT
MSG91_WHATSAPP_NUMBER=
MSG91_TEMPLATE_OTP=
MSG91_TEMPLATE_EMERGENCY_MR=
MSG91_TEMPLATE_EMERGENCY_HI=
MSG91_TEMPLATE_THANKYOU_MR=
MSG91_TEMPLATE_REMINDER_MR=
MSG91_TEMPLATE_CRED=

# ──────────────── LeegAlly (Aadhaar eSign) ────────────────
LEEGALLY_API_KEY=
LEEGALLY_TEMPLATE_ID=
LEEGALLY_BASE_URL=https://api.leegally.com

# ──────────────── LGD (Local Government Directory) ────────────────
# Public dataset from Ministry of Panchayati Raj. Either CSV (download from lgdirectory.gov.in)
# or API. Set USE_API=true to fetch live; otherwise importer reads CSVs from data/lgd/.
LGD_USE_API=true
LGD_API_BASE=https://lgdirectory.gov.in/api
LGD_API_KEY=
LGD_CSV_DIR=./data/lgd
